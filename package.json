{
  "name": "coparentes-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "prisma generate",
    "start": "bash scripts/railway-start.sh",
    "db:generate": "prisma generate",
    "db:migrate": "prisma generate && prisma migrate deploy",
    "db:push": "prisma generate && prisma db push",
    "db:seed": "ALLOW_SEED=true SEED_DEMO_DATA=true node -e \"import('./src/lib/seed.js').then(m=>m.seedDemoData()).then(()=>process.exit(0))\"",
    "db:seed:test": "ALLOW_SEED=true node scripts/seed-test-user.js",
    "test": "node --test tests/flutter-api.test.js tests/security.test.js tests/serializers.test.js tests/category-channel.test.js tests/crypto.service.test.js tests/consent.service.test.js tests/otp.service.test.js tests/security-headers.test.js tests/workspace-isolation.test.js tests/workspace-invite.test.js",
    "test:e2e": "RUN_E2E=true node --test tests/e2e-flow.test.js",
    "test:all": "node --test tests/flutter-api.test.js tests/security.test.js tests/e2e-flow.test.js",
    "test:e2e:full": "RUN_E2E=true node --test tests/flutter-api.test.js tests/security.test.js tests/e2e-flow.test.js",
    "verify:flutter": "bash scripts/verify-flutter-api.sh",
    "check:env": "node scripts/check-env.js",
    "smoke:health": "node scripts/smoke-health.js",
    "smoke:cors": "node scripts/smoke-cors.js",
    "probe:endpoints": "node scripts/probe-endpoints.js",
    "db:up": "node scripts/db-up.js",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "prisma": "^6.8.2",
    "resend": "^4.0.1",
    "tesseract.js": "^5.1.1",
    "uuid": "^11.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "embedded-postgres": "^17.6.0-beta.15",
    "pg": "^8.21.0"
  }
}

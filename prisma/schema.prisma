// Coparentes — domain schema (PostgreSQL)
// InviteCode: pole Workspace.inviteCode (kod dołączenia przez POST /api/auth/join)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  parentA
  parentB
  child
  observer
}

enum EmailInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum MessageTone {
  neutral
  tense
  aggressive
  positive
}

enum ExportType {
  messages
  calendar
  finances
  fullPack
}

enum ExportStatus {
  pending
  processing
  completed
  failed
}

enum CalendarEventType {
  school
  medical
  activity
  handover
  holiday
  other
}

enum SwapStatus {
  pending
  accepted
  rejected
  counterProposed
}

enum CustodySchedulePattern {
  weekAlternating
  everyOtherWeekend
  customWeek
}

enum CustodyScheduleStatus {
  draft
  pendingApproval
  active
  superseded
}

enum CustodySlotSource {
  schedule
  exception
  manual
  swap
}

enum CustodyExceptionType {
  singleDay
  range
  holiday
}

enum CustodyExceptionStatus {
  pending
  accepted
  rejected
}

enum ExpenseStatus {
  pending
  accepted
  disputed
  settled
}

enum ThreadAudience {
  parents
  family
}

enum ConsentType {
  TERMS
  DATA_PROCESSING
  CHILD_DATA
  EMAIL_NOTIFICATIONS
  MARKETING
  ANALYTICS
}

/// Przestrzeń współrodzicielska (rodzina). inviteCode = kod zaproszenia dla parentB / child / observer.
model Workspace {
  id              String   @id @default(cuid())
  name            String
  inviteCode      String   @unique
  childInviteCode String   @unique
  inviteCodeExpiresAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users      User[]
  children   Child[]
  threads    Thread[]
  messages   Message[]
  exportJobs ExportJob[]
  custodySlots  CustodySlot[]
  custodySchedules CustodySchedule[]
  custodyExceptions CustodyException[]
  calendarEvents CalendarEvent[]
  swapRequests   SwapRequest[]
  expenses       Expense[]
  documents      Document[]
  emailInvites   EmailInvite[]
  messageUserTags MessageUserTag[]

  @@index([inviteCode])
  @@index([childInviteCode])
}

model User {
  id               String    @id @default(cuid())
  workspaceId      String?
  workspace        Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name             String
  email            String    @unique
  passwordHash     String
  role             UserRole  @default(parentA)
  twoFactorEnabled Boolean   @default(false)
  highConflictMode Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions         Session[]
  sentEmailInvites EmailInvite[] @relation("SentEmailInvites")
  loginOtpChallenges LoginOtpChallenge[]
  trustedDevices   TrustedDevice[]
  threadsCreated   Thread[]      @relation("ThreadCreator")
  messages         Message[]
  exportJobs       ExportJob[]
  calendarEvents   CalendarEvent[] @relation("CalendarEventCreator")
  swapRequests     SwapRequest[]   @relation("SwapRequester")
  custodySchedulesProposed CustodySchedule[] @relation("ScheduleProposer")
  custodyExceptionsRequested CustodyException[] @relation("ExceptionRequester")
  expensesPaid     Expense[]       @relation("ExpensePayer")
  documentsUploaded Document[]     @relation("DocumentUploader")
  childProfileId    String?          @unique
  childProfile      Child?           @relation("ChildLinkedAccount", fields: [childProfileId], references: [id], onDelete: SetNull)
  consents          UserConsent[]
  messageUserTags   MessageUserTag[]

  @@index([email])
  @@index([workspaceId])
}

/// Audit trail zgód RODO (append-only — każda zmiana = nowy wiersz).
model UserConsent {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType    ConsentType
  granted        Boolean
  grantedAt      DateTime
  ipAddressHash  String
  consentVersion String
  revokedAt      DateTime?
  createdAt      DateTime    @default(now())

  @@index([userId, consentType, grantedAt])
  @@index([userId])
}

model Child {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  dateOfBirth DateTime
  school      String?
  createdAt   DateTime  @default(now())

  threads Thread[]

  calendarEvents CalendarEvent[]
  expenses       Expense[]
  documents      Document[]
  linkedAccount  User?      @relation("ChildLinkedAccount")

  @@index([workspaceId])
}

/// Family document vault entry (metadata + optional inline file for MVP).
model Document {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title         String
  category      String
  childId       String?
  child         Child?    @relation(fields: [childId], references: [id], onDelete: SetNull)
  fileName      String?
  mimeType      String?
  fileUrl       String?
  contentBase64 String?   @db.Text
  sizeBytes     Int       @default(0)
  uploadedById  String
  uploadedBy    User      @relation("DocumentUploader", fields: [uploadedById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workspaceId])
  @@index([category])
  @@index([updatedAt])
}

/// Token sesji API (Bearer) — zamiast JWT; zgodne z Flutter AuthRepository.
model Session {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model Thread {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subject      String
  category     String
  childId      String?
  child        Child?    @relation(fields: [childId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User      @relation("ThreadCreator", fields: [createdById], references: [id])
  createdAt    DateTime       @default(now())
  lastActivity DateTime       @default(now())
  audience     ThreadAudience @default(parents)

  messages   Message[]
  exportJobs ExportJob[]

  @@index([workspaceId])
  @@index([lastActivity])
  @@index([audience])
}

model Message {
  id          String      @id @default(cuid())
  threadId    String
  thread      Thread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User        @relation(fields: [senderId], references: [id])
  senderName  String
  content     String
  tone        MessageTone @default(neutral)
  sentAt      DateTime    @default(now())
  isDelivered Boolean     @default(true)
  isRead      Boolean     @default(false)
  hash        String
  attachmentsJson String? @db.Text
  userTags    MessageUserTag[]

  @@index([threadId])
  @@index([workspaceId])
  @@index([sentAt])
}

/// Prywatny tag użytkownika przypisany do wiadomości (widoczny tylko dla właściciela).
model MessageUserTag {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId   String
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  threadId    String
  tag         String
  createdAt   DateTime @default(now())

  @@unique([userId, messageId, tag])
  @@index([userId, workspaceId, tag])
  @@index([userId, threadId])
}

/// Zadanie eksportu dowodów (messages / calendar / finances / fullPack).
model ExportJob {
  id            String       @id @default(cuid())
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User         @relation(fields: [requestedById], references: [id])
  type          ExportType
  threadId      String?
  thread        Thread?      @relation(fields: [threadId], references: [id], onDelete: SetNull)
  fromDate      DateTime
  toDate        DateTime
  status        ExportStatus @default(completed)
  downloadUrl   String?
  manifestHash  String?
  payloadJson   String       @db.Text
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())

  @@index([workspaceId])
  @@index([createdAt])
  @@index([threadId])
  @@index([expiresAt])
}

/// OTP e-mail po logowaniu (hash bcrypt, ważność 10 min).
model LoginOtpChallenge {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash       String
  expiresAt      DateTime
  used           Boolean  @default(false)
  failedAttempts Int      @default(0)
  lastSentAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([userId, used, expiresAt])
}

/// Zaufane urządzenie — pomija OTP przez 30 dni.
model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Zaproszenie e-mailowe (osobny flow od Workspace.inviteCode).
model EmailInvite {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  token      String            @unique
  status     EmailInviteStatus @default(PENDING)
  inviterId  String
  inviter    User              @relation("SentEmailInvites", fields: [inviterId], references: [id], onDelete: Cascade)
  acceptedBy String?
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([email])
  @@index([status])
  @@index([inviterId])
  @@index([workspaceId])
}

model CustodySlot {
  id               String           @id @default(cuid())
  workspaceId      String
  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  date             DateTime
  custodian        UserRole
  handoverLocation String?
  handoverTime     String?
  source           CustodySlotSource @default(schedule)
  scheduleId       String?
  schedule         CustodySchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  exceptionId      String?
  createdAt        DateTime         @default(now())

  @@unique([workspaceId, date])
  @@index([workspaceId])
  @@index([date])
  @@index([scheduleId])
}

model CustodySchedule {
  id               String                 @id @default(cuid())
  workspaceId      String
  workspace        Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patternType      CustodySchedulePattern
  startDate        DateTime
  endDate          DateTime?
  weekAJson        String                 @db.Text
  weekBJson        String                 @db.Text
  handoverTime     String?
  handoverLocation String?
  status           CustodyScheduleStatus  @default(pendingApproval)
  proposedById     String
  proposedBy       User                   @relation("ScheduleProposer", fields: [proposedById], references: [id])
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  slots            CustodySlot[]

  @@index([workspaceId])
  @@index([status])
}

model CustodyException {
  id            String                 @id @default(cuid())
  workspaceId   String
  workspace     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromDate      DateTime
  toDate        DateTime
  custodian     UserRole
  exceptionType CustodyExceptionType   @default(singleDay)
  reason        String?
  status        CustodyExceptionStatus @default(pending)
  requesterId   String
  requester     User                   @relation("ExceptionRequester", fields: [requesterId], references: [id])
  responseNote  String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([workspaceId])
  @@index([status])
  @@index([fromDate])
}

model CalendarEvent {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  type        CalendarEventType @default(other)
  childId     String?
  child       Child?            @relation(fields: [childId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User              @relation("CalendarEventCreator", fields: [createdById], references: [id])
  location    String?
  createdAt   DateTime          @default(now())

  @@index([workspaceId])
  @@index([startDate])
}

model SwapRequest {
  id           String     @id @default(cuid())
  workspaceId  String
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requesterId  String
  requester    User       @relation("SwapRequester", fields: [requesterId], references: [id])
  requesterName String
  originalDate DateTime
  proposedDate DateTime
  reason       String?
  status       SwapStatus @default(pending)
  responseNote String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([workspaceId])
  @@index([status])
}

model Expense {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  amount      Float
  currency    String        @default("PLN")
  category    String
  childId     String?
  child       Child?        @relation(fields: [childId], references: [id], onDelete: SetNull)
  paidById    String
  paidBy      User          @relation("ExpensePayer", fields: [paidById], references: [id])
  splitRatio  Float
  date        DateTime
  receiptUrl  String?
  receiptContentBase64 String?
  receiptMimeType      String?
  status      ExpenseStatus @default(pending)
  note        String?
  hash        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([workspaceId])
  @@index([date])
  @@index([status])
}

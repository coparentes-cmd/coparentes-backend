# =============================================================================
# Coparentes Backend — szablon zmiennych środowiskowych
# =============================================================================
# Szybki start (lokalnie):
#   cp .env.example .env
#   # Edytuj DATABASE_URL (PostgreSQL musi działać)
#   node scripts/check-env.js
#   npm run db:migrate
#   npm run dev
#
# Flutter Web (debug) łączy się z http://localhost:3000/api — patrz README.pl.md
# =============================================================================

# --- LOCAL DEV (wymagane) ----------------------------------------------------

# PostgreSQL — utwórz bazę np.: createdb coparentes
DATABASE_URL=postgresql://user:password@localhost:5432/coparentes

# URL frontendu (Flutter Web domyślnie na porcie 8080)
FRONTEND_URL=http://localhost:8080

# Dozwolone originy CORS (oddziel przecinkami)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Port API (domyślnie 3000)
PORT=3000

# development | production
NODE_ENV=development

# Publiczny URL backendu (linki w exportach, zaproszeniach)
PUBLIC_BASE_URL=http://localhost:3000

# --- LOCAL DEV (opcjonalne) --------------------------------------------------

# Regexy CORS (oddzielone przecinkami). Domyślnie obejmują Netlify + coparentes.ai
CORS_ORIGIN_PATTERNS=

# Czas życia sesji Bearer (dni)
SESSION_TTL_DAYS=30

# Seed bazy — TYLKO lokalnie. NIGDY nie ustawiaj ALLOW_SEED=true na produkcji.
ALLOW_SEED=true
SEED_DEMO_DATA=true

# Jawny seed użytkownika testowego: npm run db:seed:test
# Wymaga ALLOW_SEED=true oraz SEED_TEST_PASSWORD.
SEED_TEST_USER=
SEED_TEST_EMAIL=test@coparentes.app
SEED_TEST_PASSWORD=

# E-mail (Resend) — opcjonalnie lokalnie; bez klucza zaproszenia mogą nie wychodzić
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Ważność kodu zaproszenia (dni)
INVITE_EXPIRES_DAYS=7

# HMAC dla hashy manifestów exportu (zalecane na produkcji)
INTEGRITY_SECRET=

# Dni do wygaśnięcia i usunięcia payloadów exportu
EXPORT_TTL_DAYS=30

# --- PRODUKCJA (Railway + Netlify) — przykład --------------------------------
# FRONTEND_URL=https://twoja-aplikacja.netlify.app
# CORS_ORIGINS=https://twoja-aplikacja.netlify.app,https://coparentes.ai
# PUBLIC_BASE_URL=https://coparentes-backend-production.up.railway.app
# NODE_ENV=production
# ALLOW_SEED=false
# SEED_DEMO_DATA=false
# INTEGRITY_SECRET=wygeneruj-długi-losowy-sekret

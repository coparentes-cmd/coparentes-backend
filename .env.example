# =============================================================================
# Coparentes Backend — szablon zmiennych środowiskowych
# =============================================================================
# Szybki start (lokalnie):
#   cp .env.example .env
#   # Edytuj DATABASE_URL (PostgreSQL musi działać)
#   node scripts/check-env.js
#   npm run db:migrate
#   npm run dev
#
# Flutter Web (debug) łączy się z http://localhost:3000/api — patrz README.pl.md
# =============================================================================

# --- LOCAL DEV (wymagane) ----------------------------------------------------

# PostgreSQL — utwórz bazę np.: createdb coparentes
DATABASE_URL=postgresql://user:password@localhost:5432/coparentes

# URL frontendu (Flutter Web domyślnie na porcie 8080)
FRONTEND_URL=http://localhost:8080

# Dozwolone originy CORS (oddziel przecinkami)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Port API (domyślnie 3000)
PORT=3000

# development | production
NODE_ENV=development

# Publiczny URL backendu (linki w exportach, zaproszeniach)
PUBLIC_BASE_URL=http://localhost:3000

# --- LOCAL DEV (opcjonalne) --------------------------------------------------

# Regexy CORS (oddzielone przecinkami). Domyślnie obejmują Netlify + coparentes.ai
CORS_ORIGIN_PATTERNS=

# Czas życia sesji Bearer (dni)
SESSION_TTL_DAYS=30

# Seed bazy — TYLKO lokalnie. NIGDY nie ustawiaj ALLOW_SEED=true na produkcji.
ALLOW_SEED=true
SEED_DEMO_DATA=true
# Wymagane przy: npm run db:seed (nie commituj prawdziwego hasła).
SEED_DEMO_PASSWORD=

# Jawny seed użytkownika testowego: npm run db:seed:test
# Wymaga ALLOW_SEED=true oraz SEED_TEST_PASSWORD.
SEED_TEST_USER=
SEED_TEST_EMAIL=test@coparentes.app
SEED_TEST_PASSWORD=

# E-mail (Resend) — wymagane do 2FA e-mail i zaproszeń
# Użyj klucza LIVE (re_...), nie testowego — testowy wysyła tylko na adres właściciela konta Resend.
# Domena nadawcy musi być zweryfikowana w panelu Resend (np. getcoparentes.app).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Coparentes <noreply@getcoparentes.app>

# Ważność kodu zaproszenia e-mail (dni)
INVITE_EXPIRES_DAYS=7

# Ważność kodu zaproszenia dla drugiego rodzica (godziny)
PARENT_INVITE_TTL_HOURS=24

# HMAC dla hashy manifestów exportu (zalecane na produkcji)
INTEGRITY_SECRET=

# Dni do wygaśnięcia i usunięcia payloadów exportu
EXPORT_TTL_DAYS=30

# --- BEZPIECZEŃSTWO -----------------------------------------------------------

# Wymuszaj HTTPS w produkcji (domyślnie true gdy NODE_ENV=production)
FORCE_HTTPS=true

# Klucze AES-256 (32 bajty, base64) — NIGDY nie commituj prawdziwych wartości
# Wygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KEY_HEALTH=
KEY_FINANCE=
KEY_MESSAGES=
KEY_GENERAL=

# Weryfikacja OTP e-mailem po logowaniu (false tylko lokalnie/testy)
OTP_ENABLED=true
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
TRUSTED_DEVICE_TTL_DAYS=30

# --- PRODUKCJA (Railway + Netlify) — przykład --------------------------------
# FRONTEND_URL=https://getcoparentes.app
# CORS_ORIGINS=https://getcoparentes.app,https://www.getcoparentes.app
# PUBLIC_BASE_URL=https://coparentes-backend-production.up.railway.app
# NODE_ENV=production
# ALLOW_SEED=false
# SEED_DEMO_DATA=false
# INTEGRITY_SECRET=wygeneruj-długi-losowy-sekret

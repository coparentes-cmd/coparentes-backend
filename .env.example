DATABASE_URL=postgresql://user:password@localhost:5432/coparentes
FRONTEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Optional regex patterns (comma-separated). Defaults include Netlify + coparentes.ai
CORS_ORIGIN_PATTERNS=
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3000
SESSION_TTL_DAYS=30
# Seeding is disabled unless ALLOW_SEED=true (never set in production).
ALLOW_SEED=true
SEED_DEMO_DATA=true
# Explicit test-user seed: npm run db:seed:test (requires ALLOW_SEED=true + SEED_TEST_PASSWORD).
SEED_TEST_USER=
SEED_TEST_EMAIL=test@coparentes.app
SEED_TEST_PASSWORD=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
INVITE_EXPIRES_DAYS=7
# HMAC secret for export manifest hashes (recommended in production).
INTEGRITY_SECRET=
# Days until export download payloads expire and are purged.
EXPORT_TTL_DAYS=30

# Railway production example:
# FRONTEND_URL=https://your-app.netlify.app
# CORS_ORIGINS=https://your-app.netlify.app,https://coparentes.ai
# PUBLIC_BASE_URL=https://coparentes-backend-production.up.railway.app
